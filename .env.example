# ====================================
# ABK Ciraya - Environment Variables
# ====================================
# Copy this file to .env and fill in the values

# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/abk_ciraya

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-min-32-characters-long
BETTER_AUTH_URL=https://abkciraya.cloud

# Application
NODE_ENV=production
PORT=3011

# DOKU Payment Gateway (Optional - can also be configured via Admin > Pengaturan)
# Get credentials from https://dashboard.doku.com
# DOKU_CLIENT_ID=your-doku-client-id
# DOKU_SECRET_KEY=your-doku-secret-key

# Midtrans Payment Gateway (Optional - can also be configured via Admin > Pengaturan)
# Get credentials from https://dashboard.midtrans.com > Settings > Access Keys
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
# MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
